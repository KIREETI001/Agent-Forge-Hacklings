# ──────────────────────────────────────────────────────────────
# Agent-Forge-Hacklings — Environment Variables (TEMPLATE)
#
# 1. Copy this file to ".env"   ->   cp .env.example .env
# 2. Paste in the real keys you redeemed from each sponsor.
# 3. NEVER commit ".env" — it is gitignored.
# ──────────────────────────────────────────────────────────────

# TokenRouter  —  https://tokenrouter.io
TOKENROUTER_API_KEY=
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1
TOKENROUTER_MODEL=gpt-4o-mini

# Kimi (Moonshot AI)  —  https://platform.moonshot.ai
MOONSHOT_API_KEY=
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6

# Bright Data  —  https://brightdata.com
BRIGHTDATA_API_TOKEN=

# Bright Data Scraper Studio collectors
BRIGHTDATA_UNI_COLLECTOR_ID=
BRIGHTDATA_REDDIT_COLLECTOR_ID=
BRIGHTDATA_TECHASIA_COLLECTOR_ID=
BRIGHTDATA_UNI_INPUTS_JSON=
BRIGHTDATA_REDDIT_INPUTS_JSON=
BRIGHTDATA_TECHASIA_INPUTS_JSON=

# Government dataset API
# Paste the exact data.gov.sg REST endpoint for your MOE dataset here.
GOV_DATA_URL=https://data.gov.sg/datasets?query=ges&resultId=d_3c55210de27fcccda2ed0c63fdd2b352

# Daytona  —  https://www.daytona.io
DAYTONA_API_KEY=
DAYTONA_BASE_URL=https://api.daytona.io/v1


# SenseNova (SenseTime)  —  https://platform.sensenova.cn
SENSENOVA_API_KEY=
